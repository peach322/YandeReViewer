<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/contentContainer"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    tools:context=".DetailActivity">

    <!-- 分隔线1：图片区 与 标签区 的边界 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/detail_split_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.57" />

    <!-- 分隔线2：标签区 与 操作区 的边界 -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/detail_action_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.84" />

    <!-- 左：图片区（ViewPager） -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/detail_split_guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 中：标签区（可滚动） -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/detail_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/detail_action_guideline"
        app:layout_constraintStart_toStartOf="@id/detail_split_guideline"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp">

            <TextView
                android:id="@+id/artist_label"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="end"
                android:text="@string/detail_artist_label"
                android:textAppearance="?attr/textAppearanceHeadline6"
                app:layout_constraintBottom_toBottomOf="@id/artist_tags_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/artist_tags_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:chipSpacing="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/artist_label"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/divider_artist"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="#33000000"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/artist_tags_container" />

            <TextView
                android:id="@+id/copyright_label"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="@string/detail_copyright_label"
                android:textAppearance="?attr/textAppearanceHeadline6"
                app:layout_constraintBottom_toBottomOf="@id/copyright_tags_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_artist" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/copyright_tags_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:chipSpacing="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/copyright_label"
                app:layout_constraintTop_toBottomOf="@id/divider_artist" />

            <View
                android:id="@+id/divider_copyright"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="#33000000"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/copyright_tags_container" />

            <TextView
                android:id="@+id/character_label"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="@string/detail_character_label"
                android:textAppearance="?attr/textAppearanceHeadline6"
                app:layout_constraintBottom_toBottomOf="@id/character_tags_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_copyright" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/character_tags_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:chipSpacing="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/character_label"
                app:layout_constraintTop_toBottomOf="@id/divider_copyright" />

            <View
                android:id="@+id/divider_character"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="#33000000"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/character_tags_container" />

            <TextView
                android:id="@+id/general_label"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="@string/detail_tags_label"
                android:textAppearance="?attr/textAppearanceHeadline6"
                app:layout_constraintBottom_toBottomOf="@id/general_tags_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_character" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/general_tags_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:chipSpacing="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/general_label"
                app:layout_constraintTop_toBottomOf="@id/divider_character" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 右：操作区 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_area"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/detail_action_guideline"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 右上：收藏按钮（普通，不带弹出） -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_favorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:contentDescription="@string/post_favorite"
            android:visibility="visible"
            app:srcCompat="@drawable/ic_star_outline_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 右下：菜单按钮（带弹出） -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:contentDescription="@string/menu_button"
            android:visibility="visible"
            app:srcCompat="@drawable/ic_baseline_menu_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!--
            来源按钮 / 站内页按钮：初始位置与 fab_menu 重叠（visibility=gone），
            展开时由 toggleFabDrawer() 以 translationY 动画向上弹出；
            action_area 已设置 clipChildren=false 允许它们飞出容器边界。
        -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:contentDescription="@string/detail_source_button_text"
            android:visibility="gone"
            app:fabSize="mini"
            app:srcCompat="@drawable/ic_info_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_internal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:contentDescription="@string/site_page"
            android:visibility="gone"
            app:fabSize="mini"
            app:srcCompat="@drawable/baseline_arrow_outward_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
